# Copy to .env and fill in values
DATABASE_URL=postgresql://user:password@host:5432/dragonslayer
FRONTEND_URL=https://dragonslayer.up.railway.app
ADMIN_TOKEN=change-me-to-a-long-random-secret
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
PORT=8000

# XRPL server wallet for NFT minting (server mints, player claims via Xaman)
XRPL_WALLET_SEED=your-xrpl-wallet-seed
XRPL_NODE=wss://xrplcluster.com

# Backend public URL (used for self-hosted NFT image links)
BACKEND_URL=https://your-backend.up.railway.app

# Pinata IPFS — pin NFT images + metadata on mint for wallet/marketplace display
# Get JWT from https://app.pinata.cloud/keys
PINATA_JWT=your-pinata-jwt
PINATA_GATEWAY=https://your-subdomain.mypinata.cloud
